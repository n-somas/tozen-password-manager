<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.VaultController"
      prefWidth="980.0" prefHeight="670.0"
      styleClass="app-shell"
      stylesheets="@styles.css">

    <HBox alignment="CENTER_LEFT"
          spacing="10"
          styleClass="title-bar"
          onMousePressed="#onWindowMousePressed"
          onMouseDragged="#onWindowMouseDragged">
        <Label text="PMX" styleClass="titlebar-logo"/>
        <Label text="Tresor" styleClass="titlebar-window-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="_" onAction="#onMinimizeWindow" styleClass="titlebar-button"/>
        <Button text="X" onAction="#onCloseWindow" styleClass="titlebar-close-button"/>
    </HBox>

    <VBox styleClass="content-area-clean" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="14">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Tresor" styleClass="page-title"/>
                <Label text="Lokale Zugangsdaten verwalten und verschluesselt speichern." styleClass="page-subtitle"/>
            </VBox>

            <Button text="+ Neuer Eintrag" onAction="#onAddEntry" styleClass="ghost-button"/>
            <Button text="Ausloggen" onAction="#onLogout" styleClass="logout-button"/>
        </HBox>

        <VBox styleClass="panel-soft" spacing="14" VBox.vgrow="ALWAYS">
            <TextField fx:id="searchField"
                       promptText="Suche nach Website oder Benutzername..."
                       styleClass="search-input"/>

            <TableView fx:id="vaultTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="websiteColumn" text="Webseite"/>
                    <TableColumn fx:id="usernameColumn" text="Benutzername"/>
                    <TableColumn fx:id="passwordColumn" text="Passwort"/>
                    <TableColumn fx:id="actionColumn" text="Aktion"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
</VBox>